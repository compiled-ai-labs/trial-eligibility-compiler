{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://compiled-ai-labs/trial-eligibility-compiler/fixture.schema.json",
  "title": "Synthetic patient fixture",
  "description": "One hand-authored synthetic patient plus its author-asserted expected per-criterion labels. Never derived from real data.",
  "type": "object",
  "additionalProperties": false,
  "required": ["patient_id", "description", "index_date", "person", "expected"],
  "properties": {
    "patient_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "index_date": { "type": "string", "format": "date" },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gender", "birth_date"],
      "properties": {
        "gender": { "type": "string", "enum": ["MALE", "FEMALE"] },
        "birth_date": { "type": "string", "format": "date" }
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concept_id", "start_date"],
        "properties": {
          "concept_id": { "type": "integer" },
          "start_date": { "type": "string", "format": "date" },
          "label": { "type": "string" }
        }
      }
    },
    "measurements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concept_id", "date", "value"],
        "properties": {
          "concept_id": { "type": "integer" },
          "date": { "type": "string", "format": "date" },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    },
    "drugs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concept_id", "start_date", "end_date"],
        "properties": {
          "concept_id": { "type": "integer" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "label": { "type": "string" }
        }
      }
    },
    "procedures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["concept_id", "date"],
        "properties": {
          "concept_id": { "type": "integer" },
          "date": { "type": "string", "format": "date" },
          "label": { "type": "string" }
        }
      }
    },
    "expected": {
      "type": "object",
      "description": "criterion_id -> expected disposition for THIS patient. INCLUDED/EXCLUDED for determinate rules (from attrition); AMBIGUOUS for refused criteria (must be reported, never executed).",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "enum": ["INCLUDED", "EXCLUDED", "AMBIGUOUS"] }
    },
    "expected_membership": {
      "type": "boolean",
      "description": "Whether the patient ends in the cohort after all determinate inclusion rules."
    }
  }
}
